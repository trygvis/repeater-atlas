#!/bin/bash

set -euo pipefail

v=0.14.2

basedir="${0%/*}"
self="${0##*/}"

s=$(uname -s)
case "$s"
in
  Darwin) s=apple-darwin ;;
  Linux) s=unknown-linux-musl ;;
  *) echo "Unsupported system: $s" >/dev/stderr; exit 1 ;;
esac

m=$(uname -m)
case "$m"
in
  x86_64) ;;
  arm64) m=aarch64 ;;
  *) echo "Unsupported machine: $m" >/dev/stderr; exit 1 ;;
esac

url="https://github.com/typst/typst/releases/download/v$v/typst-${m}-${s}.tar.xz"
filename=${url##*/}

root="$basedir/.$self"
archive="$root/$v/$filename"
bin="$root/$v/$self"

if [[ ! -x "$bin" ]]
then
  if [[ ! -r "$archive" ]]
  then
    mkdir -p "${archive%/*}"
    wget -O "$archive" "$url"
  fi

  mkdir -p "${bin%/*}"
  tar xf "$archive" -C "${bin%/*}" --strip-components=1
fi

exec "$bin" "${@}"
