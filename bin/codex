#!/bin/bash

set -euo pipefail

v=0.104.0

basedir="${0%/*}"
self="${0##*/}"

s=$(uname -s)
case "$s"
in
  Darwin) s=apple-darwin ;;
  Linux) s=linux-gnu ;;
  *) echo "Unsupported system: $s" >/dev/stderr; exit 1 ;;
esac

m=$(uname -m)
case "$m"
in
  x86_64) ;;
  arm64) m=aarch64 ;;
  *) echo "Unsupported machine: $m" >/dev/stderr; exit 1 ;;
esac

url="https://github.com/openai/codex/releases/download/rust-v$v/codex-${m}-unknown-${s}.zst"
filename=${url##*/}

root="$basedir/.$self"
archive="$root/$filename"
bin="$root/$self-$v/$self"

if [[ ! -x "$bin" ]]
then
  if [[ ! -r "$archive" ]]
  then
    mkdir -p "${archive%/*}"
    wget -O "$archive" "$url"
  fi

  mkdir -p "${bin%/*}"
  zstdcat "$archive" > "$bin"
  chmod +x "$bin"
fi

exec "$bin" "${@}"
