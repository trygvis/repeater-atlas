#!/bin/bash

export PGHOST=${PGHOST:-localhost}
export PGDATABASE=${PGDATABASE:-repeater_atlas}
export PGUSER=${PGUSER:-repeater_atlas}
export PGPASSWORD=${PGPASSWORD:-repeater_atlas}

args=(docker compose exec)
while read -r key
do
  args+=(-e "$key")
done < <(env | sed -n "s,^\(PG.*\)=.*,\1,p")

if ! test -t 0
then
  args+=(-T)
else
  args+=(-it)
fi

args+=(postgres)
args+=("${0##*/}" "${@}")

exec "${args[@]}"
