#!/bin/bash

export PGHOST=${PGHOST:-localhost}
export PGDATABASE=${PGDATABASE:-repeater_atlas}
export PGUSER=${PGUSER:-repeater_atlas}
export PGPASSWORD=${PGUSER:-repeater_atlas}

args=(docker compose exec)
args+=(-e "PGHOST")
args+=(-e "PGDATABASE")
args+=(-e "PGUSER")
args+=(-e "PGPASSWORD")

if ! test -t 0
then
  args+=(-T)
else
  args+=(-it)
fi

args+=(postgres)
args+=(psql "${@}")

exec "${args[@]}"
