#!/bin/bash

set -euo pipefail

v=0.3.0

basedir=${0%/*}
cookie=$basedir/.cargo/prek-$v

if [[ ! -r "$cookie" ]]
then
  # Silence the warning about missing from path
  PATH="$basedir/.cargo/bin:$PATH"
  cargo install --root "$basedir/.cargo" --locked "prek@$v"

  touch "$cookie"
fi

exec "$basedir/.cargo/bin/prek" "${@}"
